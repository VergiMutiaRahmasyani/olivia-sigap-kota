APP_NAME="SigapKota"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Ganti dengan URL frontend React kamu
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database ───────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sigapkota_db
DB_USERNAME=root
DB_PASSWORD=

# ── File Storage ───────────────────────────────────────────────────────
FILESYSTEM_DISK=public

# ── Queue (gunakan 'database' untuk production sederhana) ──────────────
QUEUE_CONNECTION=sync

# ── Mail ───────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@sigapkota.id"
MAIL_FROM_NAME="${APP_NAME}"

# ── Anthropic AI (untuk analisis keparahan) ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ── Sanctum ────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000
SESSION_DOMAIN=localhost
